venv_*/

# Claude Code: track audit-rules.yaml, settings.json, workflows/ — but keep
# per-machine state (permission allowlist, agent worktrees, layer-1
# debounce stamps + findings log) out of git.
.claude/settings.local.json
.claude/worktrees/
.claude/.audit-state/
.claude/session-data/

# SBOM artifacts (generated by cargo-cyclonedx in CI; locally regen as needed)
*.cdx.json
sbom-out/

# Internal working docs — kept local only, never published to the public repo:
#   strategy/    go-to-market, competitive, outreach, A/B framing
#   audits/      auto-generated weekly deep-audit reports (Layer 3 workflow output)
#   superpowers/ maintainer plan/spec/report process artifacts
docs/strategy/
docs/audits/
docs/superpowers/

# Tooling caches
.ruff_cache/
